  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8a806a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants, numbers, and booleans",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#e19a5e"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#aac276"
      }
    },
    {
      "name": "Regular expressions and escapes",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#65b8c7"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#ef8667",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.definition.operator"
      ],
      "settings": {
        "foreground": "#eadfca",
        "fontStyle": ""
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#87c4df",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b7955a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables and properties",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#d0b88b"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#bf7c66"
      }
    },
    {
      "name": "Language and library support",
      "scope": [
        "support.variable",
        "support.other.variable",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c98243"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#ef8667",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#87c4df"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#8a806a"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#10130f",
        "background": "#ef8667",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#7d735f",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#e19a5e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#87c4df",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup emphasis",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#b7aa90",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#eadfca",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Inserted diff",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#aac276"
      }
    },
    {
      "name": "Deleted diff",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#ef8667"
      }
    },
    {
      "name": "Changed diff",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#e19a5e"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#87c4df",
    "class": {
      "foreground": "#b7955a",
      "bold": true
    },
    "enum": {
      "foreground": "#b7955a",
      "bold": true
    },
    "interface": {
      "foreground": "#b7955a",
      "bold": true
    },
    "struct": {
      "foreground": "#b7955a",
      "bold": true
    },
    "type": "#b7955a",
    "typeParameter": "#c98243",
    "parameter": "#bf7c66",
    "variable": "#d0b88b",
    "variable.readonly": "#e19a5e",
    "property": "#d0b88b",
    "property.readonly": "#e19a5e",
    "enumMember": "#e19a5e",
    "function": {
      "foreground": "#87c4df",
      "bold": true
    },
    "method": {
      "foreground": "#87c4df",
      "bold": true
    },
    "macro": "#c98243",
    "decorator": "#ef8667",
    "event": "#65b8c7",
    "operator": "#eadfca",
    "comment": {
      "foreground": "#8a806a",
      "italic": true
    },
    "string": "#aac276",
    "number": "#e19a5e",
    "regexp": "#65b8c7",
    "*.declaration": {
      "bold": true
    },
    "*.deprecated": {
      "foreground": "#7d735f",
      "strikethrough": true
    }
  }
}
