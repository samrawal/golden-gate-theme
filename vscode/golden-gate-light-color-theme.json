  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#625c4f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constants, numbers, and booleans",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#7b4b3e"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#4f6d2f"
      }
    },
    {
      "name": "Regular expressions and escapes",
      "scope": [
        "string.regexp",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#2b7a8e"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a84732"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.definition.operator"
      ],
      "settings": {
        "foreground": "#2b2f29",
        "fontStyle": ""
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#1e668e"
      }
    },
    {
      "name": "Types and classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#7a5b2e"
      }
    },
    {
      "name": "Variables and properties",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#4f463c"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#7b4b3e"
      }
    },
    {
      "name": "Language and library support",
      "scope": [
        "support.variable",
        "support.other.variable",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#7d5412"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#a84732"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#1e668e"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#625c4f"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#fffaf0",
        "background": "#a84732",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Deprecated",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#8a7e6d",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#a84732",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#1e668e",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup emphasis",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#625c4f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#2b2f29",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Inserted diff",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#4f6d2f"
      }
    },
    {
      "name": "Deleted diff",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#a84732"
      }
    },
    {
      "name": "Changed diff",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#7d5412"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#1e668e",
    "class": {
      "foreground": "#7a5b2e"
    },
    "enum": {
      "foreground": "#7a5b2e"
    },
    "interface": {
      "foreground": "#7a5b2e"
    },
    "struct": {
      "foreground": "#7a5b2e"
    },
    "type": "#7a5b2e",
    "typeParameter": "#7d5412",
    "parameter": "#7b4b3e",
    "variable": "#4f463c",
    "variable.readonly": "#7b4b3e",
    "property": "#4f463c",
    "property.readonly": "#7b4b3e",
    "enumMember": "#7b4b3e",
    "function": {
      "foreground": "#1e668e"
    },
    "method": {
      "foreground": "#1e668e"
    },
    "macro": "#7a5b2e",
    "decorator": "#a84732",
    "event": "#2b7a8e",
    "operator": "#2b2f29",
    "comment": {
      "foreground": "#625c4f",
      "italic": true
    },
    "string": "#4f6d2f",
    "number": "#7b4b3e",
    "regexp": "#2b7a8e",
    "*.deprecated": {
      "foreground": "#8a7e6d",
      "strikethrough": true
    }
  }
}
